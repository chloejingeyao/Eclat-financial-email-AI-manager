# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → enable the Gmail API
# 3. Create OAuth 2.0 credentials (type: Desktop App)
# 4. Copy the Client ID and Client Secret below
# 5. Run `npm run auth` to complete the Gmail sign-in flow
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# ── AI Model API Keys ─────────────────────────────────────────────────────────
# You can also set these in the extension Settings tab — no .env required.
#
# Gemini (default) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Claude Haiku — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
