{
  "name": "finance-sentinel",
  "version": "1.0.0",
  "description": "Autonomous agent that surfaces financial signals from your inbox",
  "type": "module",
  "scripts": {
    "auth": "node src/auth.js",
    "fetch": "node src/fetchEmails.js",
    "analyze": "node src/analyzeEmails.js",
    "scan": "node src/fetchEmails.js && node src/analyzeEmails.js",
    "server": "node src/server.js",
    "server:restart": "lsof -ti:3001 | xargs kill -9 2>/dev/null; node src/server.js",
    "dev": "concurrently \"npm run server\" \"npm run dev --prefix frontend\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/generative-ai": "^0.21.0",
    "cheerio": "^1.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.0",
    "open": "^10.1.0"
  }
}
